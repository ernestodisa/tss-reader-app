# ─────────────────────────────────────────────────────────────────
# Speechify Clone — Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# TTS Worker URL
# The deployed Cloudflare Worker that handles text-to-speech requests.
# During local development this defaults to http://localhost:8787
# When deploying to production, set this to your deployed Worker URL:
#   Example: https://speechify-tts.your-subdomain.workers.dev
VITE_WORKER_URL=http://localhost:8787
